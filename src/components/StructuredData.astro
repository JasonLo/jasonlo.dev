---
import { siteConfig } from '../config';

interface WebSiteData {
  name?: string;
  description?: string;
  url?: string;
}

interface PersonData {
  name?: string;
  jobTitle?: string;
  description?: string;
  url?: string;
  email?: string;
  image?: string;
  socialLinks?: string[];
  skills?: string[];
}

interface ProjectData {
  title: string;
  description?: string;
  outcomeSummary?: string;
  authorName?: string;
  year?: number;
  techStack?: string[];
  problem?: string;
  impact?: string;
}

interface ArticleData {
  title: string;
  description?: string;
  authorName?: string;
  publishDate?: Date;
  updatedDate?: Date;
  image?: string;
  url?: string;
  tags?: string[];
}

interface BreadcrumbData {
  items?: { name: string; url: string }[];
}

type Props =
  | { type: 'WebSite'; data?: WebSiteData }
  | { type: 'Person'; data?: PersonData }
  | { type: 'Project'; data: ProjectData }
  | { type: 'Article'; data: ArticleData }
  | { type: 'BreadcrumbList'; data: BreadcrumbData };

const props = Astro.props as Props;

const siteURL = siteConfig.url.endsWith('/') ? siteConfig.url.slice(0, -1) : siteConfig.url;
const socialLinks = Object.values(siteConfig.social).filter(Boolean);
const baseContext = 'https://schema.org';

function generateStructuredData(): Record<string, unknown> | null {
  switch (props.type) {
    case 'WebSite': {
      const d = props.data ?? {};
      return {
        '@context': baseContext,
        '@type': 'WebSite',
        name: d.name ?? siteConfig.title,
        description: d.description ?? siteConfig.description,
        url: d.url ?? siteURL,
        inLanguage: siteConfig.language,
        author: {
          '@type': 'Person',
          name: siteConfig.author.name,
          jobTitle: siteConfig.author.title,
          url: siteURL,
        },
      };
    }

    case 'Project': {
      const d = props.data;
      return {
        '@context': baseContext,
        '@type': 'CreativeWork',
        name: d.title,
        description: d.description ?? d.outcomeSummary,
        author: {
          '@type': 'Person',
          name: d.authorName ?? siteConfig.author.name,
        },
        dateCreated: d.year ? `${d.year}-01-01` : undefined,
        keywords: d.techStack?.join(', '),
        about: d.problem,
        result: d.impact,
      };
    }

    case 'Article': {
      const d = props.data;
      return {
        '@context': baseContext,
        '@type': 'Article',
        headline: d.title,
        description: d.description,
        author: {
          '@type': 'Person',
          name: d.authorName ?? siteConfig.author.name,
          url: siteURL,
        },
        datePublished: d.publishDate?.toISOString(),
        dateModified: d.updatedDate?.toISOString() ?? d.publishDate?.toISOString(),
        image: d.image ?? `${siteURL}/og-image.png`,
        publisher: {
          '@type': 'Person',
          name: siteConfig.author.name,
          url: siteURL,
        },
        mainEntityOfPage: {
          '@type': 'WebPage',
          '@id': d.url ?? Astro.url.href,
        },
        keywords: d.tags?.join(', '),
        inLanguage: siteConfig.language,
      };
    }

    case 'Person': {
      const d = props.data ?? {};
      return {
        '@context': baseContext,
        '@type': 'Person',
        name: d.name ?? siteConfig.author.name,
        jobTitle: d.jobTitle ?? siteConfig.author.title,
        description: d.description ?? siteConfig.author.bio,
        url: d.url ?? siteURL,
        sameAs: d.socialLinks ?? socialLinks,
        email: d.email ?? siteConfig.author.email,
        image: d.image,
        knowsAbout: d.skills ?? [],
      };
    }

    case 'BreadcrumbList': {
      const d = props.data;
      return {
        '@context': baseContext,
        '@type': 'BreadcrumbList',
        itemListElement: d.items?.map((item, index) => ({
          '@type': 'ListItem',
          position: index + 1,
          name: item.name,
          item: item.url.startsWith('http') ? item.url : `${siteURL}${item.url}`,
        })),
      };
    }
  }
}

const structuredData = generateStructuredData();
const json = structuredData
  ? JSON.stringify(structuredData, (_, v) => (v == null ? undefined : v), 2)
  : null;
---

{json && <script is:inline type="application/ld+json" set:html={json} />}
