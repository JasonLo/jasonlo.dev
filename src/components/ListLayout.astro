---
import BaseLayout from '../layouts/BaseLayout.astro';
import SEO from './SEO.astro';

interface SortOption {
  key: string;
  label: string;
}

interface Props {
  title: string;
  intro: string;
  itemCount: number;
  itemLabel: string;
  statsExtra?: string;
  sortOptions?: SortOption[];
  defaultSort?: string;
  listId: string;
  emptyMessage: string;
  description: string;
  pageSize?: number;
}

const { title, intro, itemCount, itemLabel, statsExtra, sortOptions, defaultSort, listId, emptyMessage, description, pageSize } = Astro.props;
---

<BaseLayout>
  <SEO
    slot="head"
    title={title}
    description={description}
    type="website"
  />

  <div class="page-container" data-reveal-group>
    <header class="page-header" data-reveal>
      <h1 class="page-title">{title}</h1>
      <p class="page-intro">
        {intro}
      </p>
      <div class="page-controls">
        <p class="page-stats">{itemCount} {itemLabel}{statsExtra ? ` · ${statsExtra}` : ''}</p>
        {sortOptions && sortOptions.length > 0 && (
          <div class="sort-controls" role="group" aria-labelledby="sort-label">
            <span class="sort-label" id="sort-label">Sort by</span>
            {sortOptions.map((option) => (
              <button
                type="button"
                class:list={['sort-btn', { active: option.key === defaultSort }]}
                data-sort-key={option.key}
                aria-pressed={option.key === defaultSort}
              >
                {option.label}
              </button>
            ))}
          </div>
        )}
        <div role="status" class="sort-status visually-hidden" aria-live="polite" aria-atomic="true"></div>
      </div>
    </header>

    {itemCount > 0 ? (
      <div class="row-list" id={listId} data-reveal>
        <slot />
      </div>
    ) : (
      <p class="empty-state" data-reveal>{emptyMessage}</p>
    )}
    {pageSize && itemCount > pageSize && (
      <nav class="pagination" aria-label="Page navigation" id={`${listId}-pagination`} data-page-size={pageSize}>
        <button type="button" class="page-btn" id={`${listId}-prev`} aria-label="Previous page" disabled>← Prev</button>
        <span class="page-indicator" aria-live="polite" aria-atomic="true">
          Page <span id={`${listId}-page-current`}>1</span> of <span id={`${listId}-page-total`}>{Math.ceil(itemCount / pageSize)}</span>
        </span>
        <button type="button" class="page-btn" id={`${listId}-next`} aria-label="Next page">Next →</button>
      </nav>
    )}
  </div>
</BaseLayout>

<script>
  document.addEventListener('astro:page-load', () => {
    document.querySelectorAll<HTMLElement>('.page-container').forEach(wireContainer);
  });

  function wireContainer(container: HTMLElement) {
    if (container.dataset.wired === 'true') return;
    container.dataset.wired = 'true';

    const list = container.querySelector<HTMLElement>('.row-list');
    if (!list) return;

    const pagination = document.getElementById(list.id + '-pagination');
    const pageSize = pagination ? parseInt(pagination.dataset.pageSize ?? '10', 10) : 0;
    const state = { currentPage: 1, pageSize, list };

    container.querySelectorAll<HTMLElement>('.sort-btn').forEach((btn) => {
      btn.addEventListener('click', () => onSortClick(btn, container, state));
    });

    if (pagination) {
      wirePagination(list.id, state);
      jumpToHash(state);
      applyPage(state);
    }
  }

  type State = { currentPage: number; pageSize: number; list: HTMLElement };

  function onSortClick(btn: HTMLElement, container: HTMLElement, state: State) {
    const key = btn.getAttribute('data-sort-key');
    if (!key) return;

    container.querySelectorAll('.sort-btn').forEach((b) => {
      b.classList.remove('active');
      b.setAttribute('aria-pressed', 'false');
    });
    btn.classList.add('active');
    btn.setAttribute('aria-pressed', 'true');

    const statusEl = container.querySelector('.sort-status');
    if (statusEl) statusEl.textContent = `Sorted by ${btn.textContent?.trim() ?? key}`;

    const items = [...state.list.querySelectorAll<HTMLElement>('.row-item')];
    const vals = items.map((el) => el.getAttribute('data-sort-' + key) ?? '');
    const numeric = vals.every((v) => v !== '' && !isNaN(Number(v)));

    const indices = items.map((_, i) => i);
    indices.sort((a, b) =>
      numeric ? Number(vals[b]) - Number(vals[a]) : vals[a].localeCompare(vals[b])
    );
    indices.forEach((i) => state.list.appendChild(items[i]));

    if (state.pageSize > 0) {
      state.currentPage = 1;
      applyPage(state);
    }
  }

  function wirePagination(listId: string, state: State) {
    document.getElementById(listId + '-prev')?.addEventListener('click', () => {
      if (state.currentPage > 1) {
        state.currentPage--;
        applyPage(state);
        state.list.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });

    document.getElementById(listId + '-next')?.addEventListener('click', () => {
      const totalPages = Math.ceil(getItems(state.list).length / state.pageSize);
      if (state.currentPage < totalPages) {
        state.currentPage++;
        applyPage(state);
        state.list.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }
    });
  }

  function jumpToHash(state: State) {
    const hash = window.location.hash.slice(1);
    if (!hash) return;
    const items = getItems(state.list);
    const targetIndex = items.findIndex((item) => item.id === hash);
    if (targetIndex >= 0) {
      state.currentPage = Math.floor(targetIndex / state.pageSize) + 1;
      requestAnimationFrame(() => {
        const target = document.getElementById(hash);
        if (target && target.style.display !== 'none') {
          target.scrollIntoView({ block: 'start' });
        }
      });
    }
  }

  function getItems(list: HTMLElement): HTMLElement[] {
    return Array.from(list.querySelectorAll<HTMLElement>('.row-item'));
  }

  function applyPage(state: State) {
    const items = getItems(state.list);
    const totalPages = Math.max(1, Math.ceil(items.length / state.pageSize));
    state.currentPage = Math.min(state.currentPage, totalPages);
    const start = (state.currentPage - 1) * state.pageSize;
    const end = start + state.pageSize;
    items.forEach((item, i) => {
      item.style.display = i >= start && i < end ? '' : 'none';
    });

    const listId = state.list.id;
    const cur = document.getElementById(listId + '-page-current');
    const tot = document.getElementById(listId + '-page-total');
    const prev = document.getElementById(listId + '-prev') as HTMLButtonElement | null;
    const next = document.getElementById(listId + '-next') as HTMLButtonElement | null;
    if (cur) cur.textContent = String(state.currentPage);
    if (tot) tot.textContent = String(totalPages);
    if (prev) prev.disabled = state.currentPage === 1;
    if (next) next.disabled = state.currentPage === totalPages;
  }
</script>

<style>
  .page-stats {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    margin-top: 1rem;
  }

  .pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-top: 2rem;
  }

  .page-btn {
    font-size: 0.8125rem;
    padding: 0.375rem 0.875rem;
    border-radius: 4px;
    border: 1px solid var(--color-border);
    background: transparent;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all 0.15s ease;
    font-family: inherit;
  }

  .page-btn:hover:not(:disabled) {
    border-color: var(--color-text-muted);
    color: var(--color-text-secondary);
  }

  .page-btn:disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }

  .page-btn:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .page-indicator {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    min-width: 7rem;
    text-align: center;
  }
</style>
